generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  FINAL
}

enum SeasonStatus {
  SETUP
  REGISTRATION
  LOCKED
  ACTIVE
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NO_RESPONSE
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  isPaid        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ─── Profile fields (spec Section: Player Registration) ───
  firstName          String?
  lastName           String?
  username           String?   @unique
  country            String?
  state              String?
  gender             Gender?
  dateOfBirth        DateTime?
  phone              String?
  profilePhotoUrl    String?
  favoriteTeamId     String?
  favoriteTeamName   String?   // stores D1 team name (used pre-bracket when Team table is empty)
  notificationsEnabled Boolean @default(true)
  registrationComplete Boolean @default(false)

  accounts      Account[]
  sessions      Session[]
  picks         Pick[]
  entries       Entry[]
  adminLeagues  League[]  @relation("LeagueAdmin")
  favoriteTeam  Team?     @relation("FavoriteTeam", fields: [favoriteTeamId], references: [id])
}

model Season {
  id               String       @id @default(cuid())
  year             Int          @unique
  status           SeasonStatus @default(SETUP)
  entryDeadlineUtc DateTime?
  sponsorDetails   Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  entries     Entry[]
  leagues     League[]
  checkpoints Checkpoint[]
}

model League {
  id            String   @id @default(cuid())
  name          String
  inviteCode    String   @unique
  description   String?  @db.Text
  maxEntries    Int?     // null = unlimited; total entries (not unique users)
  trackPayments Boolean  @default(false)
  adminId       String
  seasonId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  admin         User          @relation("LeagueAdmin", fields: [adminId], references: [id])
  season        Season        @relation(fields: [seasonId], references: [id])
  leagueEntries LeagueEntry[]

  @@unique([name, seasonId])
}

model LeagueEntry {
  id        String   @id @default(cuid())
  leagueId  String
  entryId   String
  paid      Boolean  @default(false)
  joinedAt  DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  entry  Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([leagueId, entryId])
}

model Entry {
  id                 String   @id @default(cuid())
  userId             String
  seasonId           String
  nickname           String?
  entryNumber        Int      @default(1)
  score              Int      @default(0)
  maxPossibleScore   Int      @default(0)
  expectedScore      Float    @default(0)
  teamsAlive         Int      @default(0)
  charityPreference  String?
  draftInProgress    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  season         Season          @relation(fields: [seasonId], references: [id])
  leagueEntries  LeagueEntry[]
  entryPicks     EntryPick[]
  scoreSnapshots ScoreSnapshot[]

  @@unique([userId, seasonId, entryNumber])
}

model EntryPick {
  id           String   @id @default(cuid())
  entryId      String
  teamId       String?
  playInSlotId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entry      Entry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id])
  playInSlot PlayInSlot? @relation(fields: [playInSlotId], references: [id])

  @@unique([entryId, teamId])
  @@unique([entryId, playInSlotId])
}

model Team {
  id         String  @id @default(cuid())
  espnId     String  @unique
  name       String
  shortName  String
  seed       Int
  region     String
  isPlayIn   Boolean @default(false)
  eliminated Boolean @default(false)
  wins       Int     @default(0)
  logoUrl    String?
  sCurveRank Int?
  conference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  picks        Pick[]
  entryPicks   EntryPick[]
  playInSlot1  PlayInSlot[]     @relation("PlayInTeam1")
  playInSlot2  PlayInSlot[]     @relation("PlayInTeam2")
  playInWinner PlayInSlot[]     @relation("PlayInWinner")
  team1Games   TournamentGame[] @relation("GameTeam1")
  team2Games   TournamentGame[] @relation("GameTeam2")
  wonGames     TournamentGame[] @relation("GameWinner")
  fanUsers     User[]           @relation("FavoriteTeam")
}

model PlayInSlot {
  id       String  @id @default(cuid())
  seed     Int
  region   String
  team1Id  String
  team2Id  String
  winnerId String?

  team1      Team        @relation("PlayInTeam1", fields: [team1Id], references: [id])
  team2      Team        @relation("PlayInTeam2", fields: [team2Id], references: [id])
  winner     Team?       @relation("PlayInWinner", fields: [winnerId], references: [id])
  picks      Pick[]
  entryPicks EntryPick[]

  @@unique([seed, region])
}

// Legacy Pick model — kept for backward compatibility during migration
model Pick {
  id                String   @id @default(cuid())
  userId            String
  teamId            String?
  playInSlotId      String?
  charityPreference String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id])
  playInSlot PlayInSlot? @relation(fields: [playInSlotId], references: [id])

  @@unique([userId, teamId])
  @@unique([userId, playInSlotId])
}

model TournamentGame {
  id         String     @id @default(cuid())
  espnGameId String     @unique
  round      Int
  region     String?
  team1Id    String?
  team2Id    String?
  winnerId   String?
  team1Score Int?
  team2Score Int?
  status     GameStatus @default(SCHEDULED)
  startTime  DateTime?
  isComplete Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  team1          Team?           @relation("GameTeam1", fields: [team1Id], references: [id])
  team2          Team?           @relation("GameTeam2", fields: [team2Id], references: [id])
  winner         Team?           @relation("GameWinner", fields: [winnerId], references: [id])
  scoreSnapshots ScoreSnapshot[]
}

model Checkpoint {
  id                String    @id @default(cuid())
  seasonId          String
  gameIndex         Int
  roundLabel        String
  isSession         Boolean   @default(false)
  dailyRecapSentAt  DateTime? // Tracks when daily recap was sent for this checkpoint
  createdAt         DateTime  @default(now())

  season     Season                       @relation(fields: [seasonId], references: [id])
  dimensions CheckpointDimensionSnapshot[]

  @@unique([seasonId, gameIndex])
}

model ScoreSnapshot {
  id         String   @id @default(cuid())
  entryId    String
  gameId     String?
  score      Int
  rank       Int
  percentile Float
  maxRank    Int?
  floorRank  Int?
  savedAt    DateTime @default(now())

  entry Entry           @relation(fields: [entryId], references: [id], onDelete: Cascade)
  game  TournamentGame? @relation(fields: [gameId], references: [id])
}

model CheckpointDimensionSnapshot {
  id                     String  @id @default(cuid())
  checkpointId           String
  dimensionType          String  // global, country, state, conference, gender, fan_base, private_league
  dimensionValue         String  // e.g. "Georgia", "SEC", "Auburn", league_id, or "No Response"
  leaderEntryId          String?
  medianEntryId          String?
  rollingOptimal8Score   Int?
  hindsightOptimal8Score Int?
  totalEntries           Int     @default(0)

  checkpoint Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@unique([checkpointId, dimensionType, dimensionValue])
}

model AppSettings {
  id                      String    @id @default("main")
  picksDeadline           DateTime?
  payoutStructure         Json      @default("[]")
  defaultCharities        Json      @default("[]")
  currentSeasonId         String?
  maintenanceMode         Boolean   @default(false) // When true, redirects all non-admin users to /maintenance
  deadlineReminderSentAt  DateTime? // Tracks when 24h deadline reminder was last sent
  entriesLockedSentAt     DateTime? // Tracks when entries-locked email was last sent
  finalResultsSentAt      DateTime? // Tracks when final results email was last sent
  updatedAt               DateTime  @updatedAt
}

model ContentPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   Json?
  createdAt DateTime @default(now())
}
