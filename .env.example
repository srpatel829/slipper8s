# Neon PostgreSQL
# Use the pooler URL for DATABASE_URL, direct (non-pooler) for DIRECT_URL
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Auth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Resend (email magic links)
AUTH_RESEND_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Slipper8s <noreply@slipper8s.com>"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Vercel cron job secret (generate with: openssl rand -base64 32)
CRON_SECRET="your-cron-secret-here"

# App URL (used for email links and Open Graph)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
